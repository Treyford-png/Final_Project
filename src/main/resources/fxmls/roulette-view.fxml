<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="15" style="-fx-background-color: black;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="bsu.edu.cs.cs222.games.roulette.ControllerRoulette">

    <Label fx:id="pointsLabel" text="Points: 1000" />

    <ImageView fx:id="wheelImage" fitHeight="300" fitWidth="300" preserveRatio="true">
      <image>
         <Image url="@../images/wheel_pixel.jpg" />
      </image></ImageView>

    <Button onAction="#betRed" text="Bet Red" />
    <Button onAction="#betBlack" text="Bet Black" />

    <Button onAction="#handleSpin" text="Spin" />

</VBox>
