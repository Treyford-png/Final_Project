<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<AnchorPane fx:id="anchorPane" prefHeight="221.0" prefWidth="342.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="bsu.edu.cs.cs222.menues.log_in.LogInController">
    <children>
        <ImageView fitHeight="345.0" fitWidth="500.0" layoutX="1.0" pickOnBounds="true" preserveRatio="true">
            <image>
                <Image url="@../images/log_book_2.png" />
            </image>
        </ImageView>
        <Rectangle arcHeight="5.0" arcWidth="5.0" fill="#1f93ff00" height="343.0" stroke="#969696" strokeType="INSIDE" width="501.0" />
      <VBox layoutX="265.0" layoutY="190.0" prefHeight="96.0" prefWidth="192.0">
         <children>
            <TextField fx:id="usernameField" prefHeight="27.0" prefWidth="192.0" promptText="username" />
            <Pane prefHeight="7.0" prefWidth="192.0" />
            <PasswordField fx:id="passwordField" promptText="password" />
            <Label fx:id="messageLabel" prefHeight="18.0" prefWidth="194.0" textAlignment="CENTER" textFill="#bf1e1e">
               <font>
                  <Font name="Bradley Hand ITC" size="12.0" />
               </font>
            </Label>
         </children></VBox>
      <Button layoutX="197.0" layoutY="269.0" mnemonicParsing="false" onAction="#attemptLogIn" prefHeight="46.0" prefWidth="106.0" text="Enter Deadend" textAlignment="CENTER" wrapText="true">
         <font>
            <Font name="Engravers MT" size="12.0" />
         </font></Button>
    </children>
</AnchorPane>
