<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="343.0" prefWidth="493.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="bsu.edu.cs.cs222.menues.log_in.SignUpController">
   <children>
      <ImageView fitHeight="343.0" fitWidth="513.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../images/log_book_1.png" />
         </image>
      </ImageView>
      <VBox layoutX="269.0" layoutY="59.0" prefHeight="36.0" prefWidth="186.0">
         <children>
            <Label text="Write your name" textFill="#363636">
               <font>
                  <Font name="Bradley Hand ITC" size="18.0" />
               </font>
            </Label>
            <TextField fx:id="usernameField" />
         </children>
      </VBox>
      <VBox layoutX="269.0" layoutY="125.0" prefHeight="102.0" prefWidth="186.0">
         <children>
            <Label text="Write your password">
               <font>
                  <Font name="Bradley Hand ITC" size="16.0" />
               </font>
            </Label>
            <PasswordField fx:id="passwordField" />
            <Label layoutX="10.0" layoutY="10.0" prefHeight="38.0" prefWidth="186.0" text="minimum 8 characters, 1 upper case, lowercase, number, and symbol" textFill="#484848" textOverrun="CLIP" wrapText="true">
               <font>
                  <Font name="Bradley Hand ITC" size="12.0" />
               </font>
            </Label>
         </children>
      </VBox>
      <VBox layoutX="269.0" layoutY="220.0" prefHeight="102.0" prefWidth="186.0">
         <children>
            <Label text="Confirm your password">
               <font>
                  <Font name="Bradley Hand ITC" size="16.0" />
               </font>
            </Label>
            <PasswordField fx:id="confirmField" />
            <Label fx:id="messageLabel" prefHeight="18.0" prefWidth="192.0" textAlignment="CENTER" textFill="#cf5353" />
         </children>
      </VBox>
      <Button fx:id="signButton" layoutX="198.0" layoutY="298.0" mnemonicParsing="false" onAction="#attemptLogIn" text="Sign Book">
         <font>
            <Font name="Engravers MT" size="12.0" />
         </font>
      </Button>
   </children>
</AnchorPane>
