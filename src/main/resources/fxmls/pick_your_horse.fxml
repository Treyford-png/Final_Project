<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="212.0" prefWidth="259.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="bsu.edu.cs.cs222.games.horse_race.HorsePickerController">
   <children>
      <VBox alignment="CENTER" prefHeight="212.0" prefWidth="261.0" spacing="10.0" style="-fx-background-color: #dfd7cc;">
         <children>
            <Label text="PICK A HORSE">
               <font>
                  <Font name="Playbill" size="32.0" />
               </font>
            </Label>
            <ChoiceBox fx:id="horseDropdown" prefHeight="26.0" prefWidth="235.0" />
            <Spinner fx:id="betSpinner" prefHeight="26.0" prefWidth="233.0" />
            <Button mnemonicParsing="false" onAction="#race" prefHeight="26.0" prefWidth="149.0" text="RACE">
               <font>
                  <Font name="Goudy Old Style Bold" size="14.0" />
               </font>
            </Button>
            <Button mnemonicParsing="false" prefHeight="26.0" prefWidth="147.0" text="EXIT">
               <font>
                  <Font name="Goudy Old Style Bold" size="14.0" />
               </font>
            </Button>
         </children>
      </VBox>
   </children>
</AnchorPane>
